{
  "name": "momei",
  "private": true,
  "type": "module",
  "scripts": {
    "release": "pnpm security:audit-deps && pnpm release:semantic",
    "release:semantic": "semantic-release",
    "build": "nuxt build",
    "dev": "nuxt dev -o",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "web-push:generate-vapid": "node scripts/setup/generate-web-push-vapid.mjs",
    "ai:check": "node scripts/ai/check-governance.mjs",
    "i18n:audit": "node scripts/i18n/audit-locale-keys.mjs",
    "i18n:check-sync": "node scripts/i18n/check-locale-parity.mjs",
    "lint": "cross-env NODE_ENV=production eslint . --fix --max-warnings 10 && pnpm -r --filter \"./packages/*\" lint",
    "lint:css": "stylelint ./**/*.{html,css,scss,sass,vue} --fix",
    "lint:md": "lint-md *.md docs/**/*.md .github/**/*.md --fix",
    "test": "vitest run",
    "test:e2e": "cross-env TEST_MODE=true playwright test",
    "test:e2e:ui": "cross-env TEST_MODE=true playwright test --ui",
    "typecheck": "nuxt typecheck",
    "commit": "cz",
    "prepare": "husky",
    "test:coverage": "vitest run --coverage",
    "test:perf": "lhci autorun",
    "test:perf:budget": "node scripts/perf/check-bundle-budget.mjs --mode=warn --output=.lighthouseci/bundle-budget-report.json --baseline=.github/perf/bundle-baseline.json",
    "test:perf:budget:strict": "node scripts/perf/check-bundle-budget.mjs --mode=error --output=.lighthouseci/bundle-budget-report.json --baseline=.github/perf/bundle-baseline.json",
    "security:audit-deps": "node scripts/security/check-dependency-risk.mjs --mode=error --allowlist=.github/security/dependency-risk-allowlist.json --min-severity=high --registry=https://registry.npmjs.org/",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e",
    "docs:check:i18n": "node scripts/docs/check-i18n-duplicates.mjs",
    "docs:check:source-of-truth": "node scripts/docs/check-source-of-truth.mjs",
    "docs:dev": "pnpm docs:check:i18n && vitepress dev docs --open",
    "docs:build": "pnpm docs:check:i18n && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deploy:wrangler": "wrangler deploy"
  },
