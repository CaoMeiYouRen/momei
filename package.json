{
  "name": "momei",
  "private": true,
  "type": "module",
  "scripts": {
    "release": "pnpm regression:pre-release && pnpm release:semantic",
    "release:check": "node scripts/release/pre-release-check.mjs --skip-test --skip-e2e",
    "release:check:full": "node scripts/release/pre-release-check.mjs",
    "release:semantic": "semantic-release",
    "ci:precheck": "node scripts/ci/workflow-precheck.mjs",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=6144 nuxt build",
    "dev": "nuxt dev -o",
    "generate": "cross-env NODE_OPTIONS=--max-old-space-size=6144 nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "web-push:generate-vapid": "node scripts/setup/generate-web-push-vapid.mjs",
    "setup:ai": "node scripts/setup/setup-ai.mjs",
    "setup:umami": "node scripts/setup/setup-umami.mjs",
    "ai:check": "node scripts/ai/check-governance.mjs",
    "ai:session:hook": "node scripts/ai-hooks/session-governance.mjs",
    "governance:check:scripts": "node scripts/governance/check-script-governance.mjs --mode=warn --output=artifacts/governance/script-governance-latest.json",
    "governance:audit:simple-duplicates": "node scripts/governance/audit-simple-duplicates.mjs --output=artifacts/governance/simple-duplicates-latest.json",
    "governance:audit:eslint-debt": "node scripts/governance/audit-eslint-debt.mjs --output=artifacts/governance/eslint-debt-latest.json",
    "governance:audit:comment-drift": "node scripts/governance/audit-comment-drift.mjs --output=artifacts/governance/comment-drift-latest.json",
    "i18n:audit": "node scripts/i18n/audit-locale-keys.mjs",
    "i18n:audit:missing": "node scripts/i18n/audit-locale-keys.mjs --only=missing --fail-on-missing",
    "i18n:audit:unused": "node scripts/i18n/audit-locale-keys.mjs --only=unused",
    "i18n:audit:duplicates": "node scripts/i18n/audit-duplicate-messages.mjs",
    "i18n:check-sync": "node scripts/i18n/check-locale-parity.mjs",
    "i18n:verify:runtime": "pnpm lint:i18n && pnpm exec vitest run --config vitest.i18n.config.ts",
    "lint": "cross-env NODE_ENV=production eslint . --fix --max-warnings 10 && pnpm -r --filter \"./packages/*\" lint",
    "lint:i18n": "cross-env NODE_ENV=production ESLINT_I18N=true eslint . --quiet",
    "lint:css": "stylelint ./**/*.{html,css,scss,sass,vue} --fix",
    "lint:md": "lint-md *.md docs/**/*.md .github/**/*.md --fix",
    "test": "vitest run",
    "test:e2e": "node scripts/testing/run-e2e.mjs",
    "test:e2e:critical": "node scripts/testing/run-e2e-critical.mjs",
    "test:e2e:review-gate": "node scripts/testing/run-review-gate-ui-baseline.mjs",
    "test:e2e:ui": "node scripts/testing/run-e2e.mjs --ui",
    "typecheck": "nuxt typecheck",
    "commit": "cz",
    "prepare": "husky",
    "test:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --coverage",
    "test:perf": "lhci autorun",
    "perf:nuxt:dev": "node scripts/perf/measure-nuxt-lifecycle.mjs --mode=dev --output=artifacts/nuxt-dev-performance.json --log-output=artifacts/nuxt-dev-performance.log",
    "perf:nuxt:build": "node scripts/perf/measure-nuxt-lifecycle.mjs --mode=build --output=artifacts/nuxt-build-performance.json --log-output=artifacts/nuxt-build-performance.log",
    "perf:nuxt:baseline": "pnpm run perf:nuxt:dev && pnpm run perf:nuxt:build",
    "perf:cpuprofile:remote": "node scripts/perf/capture-remote-cpuprofile.mjs --output=artifacts/remote-inspector.cpuprofile --metadata-output=artifacts/remote-inspector.cpuprofile.meta.json",
    "perf:fs-watch:probe:dev": "node --import ./scripts/perf/fs-watch-probe.mjs ./node_modules/nuxt/bin/nuxt.mjs dev -o",
    "test:perf:budget": "node scripts/perf/check-bundle-budget.mjs --mode=warn --output=.lighthouseci/bundle-budget-report.json --baseline=.github/perf/bundle-baseline.json",
    "test:perf:budget:strict": "node scripts/perf/check-bundle-budget.mjs --mode=error --output=.lighthouseci/bundle-budget-report.json --baseline=.github/perf/bundle-baseline.json",
    "test:perf:cwv": "node scripts/perf/cwv-baseline.mjs --output=.lighthouseci/cwv-baseline.json",
    "security:audit-deps": "node scripts/security/check-dependency-risk.mjs --policy=release --allowlist=.github/security/dependency-risk-allowlist.json --registry=https://registry.npmjs.org/",
    "security:audit-deps:daily": "node scripts/security/run-daily-dependency-audit.mjs --policy=daily --allowlist=.github/security/dependency-risk-allowlist.json --registry=https://registry.npmjs.org/",
    "security:alerts": "node scripts/security/check-github-security-alerts.mjs --mode=error --exceptions=.github/security/security-alert-exceptions.json --min-severity=high --registry=https://registry.npmjs.org/",
    "regression:weekly": "node scripts/regression/run-periodic-regression.mjs --profile=weekly",
    "regression:pre-release": "node scripts/regression/run-periodic-regression.mjs --profile=pre-release",
    "regression:phase-close": "node scripts/regression/run-periodic-regression.mjs --profile=phase-close",
    "regression:typeorm-assessment": "node scripts/regression/sync-typeorm-assessment.mjs",
    "duplicate-code:check": "node scripts/review-gate/check-duplicate-code.mjs",
    "duplicate-code:check:strict": "node scripts/review-gate/check-duplicate-code.mjs --mode=error",
    "verify": "pnpm lint && pnpm lint:i18n && pnpm typecheck && pnpm test && pnpm test:e2e",
    "review-gate:generate": "node scripts/review-gate/generate-evidence.mjs",
    "review-gate:generate:check": "node scripts/review-gate/generate-evidence.mjs --run-checks",
    "docs:check:i18n": "node scripts/docs/check-i18n-duplicates.mjs",
    "docs:check:line-count": "node scripts/docs/check-line-count.mjs",
    "docs:check:line-count:candidate": "node scripts/docs/check-line-count.mjs --profile=candidate --mode=warn",
    "docs:check:source-of-truth": "node scripts/docs/check-source-of-truth.mjs",
    "docs:check:source-of-truth:candidate": "node scripts/docs/check-source-of-truth.mjs --profile=candidate --mode=warn",
    "docs:dev": "pnpm docs:check:i18n && pnpm docs:check:line-count && vitepress dev docs --open",
    "docs:build": "pnpm docs:check:i18n && pnpm docs:check:line-count && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deploy:wrangler": "wrangler deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
