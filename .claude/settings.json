{
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node scripts/ai-hooks/session-governance.mjs --platform=claude --event=session-start",
                        "timeout": 15
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node scripts/ai-hooks/session-governance.mjs --platform=claude --event=pre-compact",
                        "timeout": 15
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node scripts/ai-hooks/session-governance.mjs --platform=claude --event=session-end",
                        "timeout": 15
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node scripts/ai-hooks/session-governance.mjs --platform=claude --event=pre-stop-check",
                        "timeout": 10
                    }
                ]
            }
        ]
    }
}