# ==========================================
# 墨梅博客 (Momei) 环境变量示例文件 (极简版)
# ==========================================
# 提示：此文件仅包含快速启动所需的最小配置。
# 如需查看完整配置项，请参考 .env.full.example 文件。

# ------------------------------------------
# 1. 基础核心配置 (Essential)
# ------------------------------------------

# 应用名称
NUXT_PUBLIC_APP_NAME=墨梅博客

# 站点 URL (用于生成 sitemap.xml)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Better Auth 的基础 URL (通常与 SITE_URL 相同)
NUXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000

# 用于加密、签名和哈希的密钥。生产环境必须设置！
# 可以使用 `openssl rand -hex 32` 生成。开发环境下会自动生成随机值。
AUTH_SECRET=

# ------------------------------------------
# 2. 数据库配置 (Database)
# ------------------------------------------

# 数据库连接 URL (SQLite, MySQL, PostgreSQL)
# 如果未配置，默认将使用本地 SQLite (database/momei.sqlite)
DATABASE_URL=sqlite://database/momei.sqlite

# ------------------------------------------
# 3. 初始化配置 (Initialization)
# ------------------------------------------

# 已初始化标志，设置后将不再显示初始化引导页面
# MOMEI_INSTALLED=true

# ------------------------------------------
# 4. 定时任务配置 (Scheduled Tasks)
# ------------------------------------------

# Vercel Cron 专用鉴权密钥
# Vercel 会自动以 Authorization: Bearer <CRON_SECRET> 调用你的任务端点
CRON_SECRET=

# 通用定时任务鉴权令牌 (用于手动触发 / 旧版 Webhook / 外部调度器)
TASKS_TOKEN=

# Webhook HMAC 签名密钥 (可选，默认使用 TASKS_TOKEN)
# 用于外部调度器 / GitHub Actions / Cloudflare / Serverless 等场景的 HMAC 验签
# WEBHOOK_SECRET=
