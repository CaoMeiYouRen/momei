# Umami optional stack for docker-compose.umami.yml
# Copy this file to .env.umami, then pass it with:
# docker compose -f docker-compose.yml -f docker-compose.umami.yml --env-file .env --env-file .env.umami up -d

UMAMI_CONTAINER_NAME=momei-umami
UMAMI_DB_CONTAINER_NAME=momei-umami-db
UMAMI_PORT=3001

UMAMI_POSTGRES_DB=umami
UMAMI_POSTGRES_USER=umami
UMAMI_POSTGRES_PASSWORD=change-me

# Generate at least 32 chars for production.
UMAMI_APP_SECRET=change-me

# Optional: keep default unless you need a custom path.
UMAMI_TRACKER_SCRIPT_NAME=script.js

# Optional: this is consumed by momei itself (not by Umami containers).
# Example:
# NUXT_PUBLIC_UMAMI_ANALYTICS={"websiteId":"your-website-id","scriptUrl":"https://analytics.example.com/script.js"}
