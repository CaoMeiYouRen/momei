{
  "name": "momei-cli",
  "version": "0.1.0",
  "description": "Momei CLI - Migration tool for importing posts from Hexo to Momei",
  "type": "module",
  "bin": {
    "momei": "dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.mjs",
    "lint": "eslint src --fix --no-warn-ignored --max-warnings 5",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "momei",
    "hexo",
    "migration",
    "blog",
    "cli"
  ],
  "author": "CaoMeiYouRen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/momei.git"
  },
  "dependencies": {
    "@momei-blog/api-client": "workspace:*",
    "cac": "^7.0.0",
    "chalk": "^5.4.1",
    "js-yaml": "^4.1.2",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^9.39.5",
    "eslint-config-cmyr": "2.3.1",
    "tsdown": "^0.22.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}