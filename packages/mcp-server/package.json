{
  "name": "momei-mcp-server",
  "version": "1.0.0",
  "description": "Momei MCP Server - AI automation via Model Context Protocol",
  "type": "module",
  "bin": {
    "momei-mcp": "dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.mjs",
    "lint": "eslint src --fix --no-warn-ignored --max-warnings 5",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench",
    "stress-test": "node scripts/stress-test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/momei.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@momei-blog/api-client": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^9.19.0",
    "eslint-config-cmyr": "^2.3.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}