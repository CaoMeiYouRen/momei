{
    "devCommand": "pnpm dev",
    "framework": "nuxtjs",
    "headers": [
        {
            "source": "/_nuxt/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.*)\\.(png|svg|ico|webp|jpg|jpeg|woff2?)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=2592000" }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400" }
            ]
        },
        {
            "source": "/sitemap(.*)\\.xml",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=3600" }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 10 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 12 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 14 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 16 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 18 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 20 * * *"
        },
        {
            "path": "/api/tasks/run-scheduled",
            "schedule": "0 22 * * *"
        }
    ]
}